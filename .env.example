# Copy this file to .env and fill in your API keys.
# .env is in .gitignore and will NOT be committed.

# ---------------------------------------------------------------------------
# Teacher LLM API keys (all 3 required for the 3×3 experiment matrix)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Student SLM access (required for gated models like Llama 3.3)
# ---------------------------------------------------------------------------
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ---------------------------------------------------------------------------
# Google Cloud (required when using Vertex AI backend for student fine-tuning)
# ---------------------------------------------------------------------------
# Option 1 (recommended): authenticate via gcloud CLI
#   gcloud auth application-default login
#
# Option 2: set a service account key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
